# Groq API — required for all LLM calls (text + vision)
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Groq model override — optional, defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Figma Personal Access Token — required for Visual QA
# Figma → Settings → Security → Personal access tokens
FIGMA_API_TOKEN=your_figma_token_here

# MongoDB connection string — required for history and Visual QA jobs
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# CORS origins — restrict to your domain before production
CORS_ORIGINS=*